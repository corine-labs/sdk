# Corine CLI configuration — copy to .env and fill with YOUR OWN values.
# NEVER commit a real key. .env is gitignored. No Corine key is embedded anywhere.

# Your Solana RPC endpoint (required). May carry your provider's key in the URL.
CORINE_RPC_URL=https://your-solana-rpc-endpoint

# Your signing key (required to trade): a Solana CLI keyfile path OR a base58 secret.
# Stays local — the CLI never transmits it.
CORINE_KEYPAIR=/path/to/your/solana-keypair.json

# Spend caps (mandatory safety backstops). Defaults if unset: 100 / 500.
CORINE_MAX_PER_TX_USD=100
CORINE_DAILY_CAP_USD=500

# Optional: your own Jupiter portal key for higher rate limits.
CORINE_JUPITER_KEY=

# Optional: turn the rug gate on (1) — off by default.
CORINE_RUG_GATE=0
